<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Compte de Resultat SYSCOHADA</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, Helvetica, sans-serif; font-size: 10px; color: #1a1a1a; background: #fff; }

    /* Header */
    .header { background: #1a237e; color: #fff; padding: 18px 24px; display: flex; justify-content: space-between; align-items: flex-start; }
    .header-left .company-name { font-size: 16px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 4px; }
    .header-left .company-details { font-size: 9px; opacity: 0.85; line-height: 1.6; }
    .header-right { text-align: right; }
    .header-right .doc-title { font-size: 17px; font-weight: 700; letter-spacing: 0.5px; }
    .header-right .doc-subtitle { font-size: 11px; opacity: 0.9; margin-top: 4px; }
    .header-right .doc-meta { font-size: 9px; opacity: 0.8; margin-top: 6px; line-height: 1.6; }

    /* Meta band */
    .meta-band { background: #e8eaf6; border-bottom: 2px solid #1a237e; padding: 8px 24px; display: flex; gap: 32px; font-size: 9px; color: #1a237e; font-weight: 600; }

    /* Content */
    .content { padding: 0 24px; }

    /* Section */
    .section { margin-top: 14px; }
    .section-header { background: #1a237e; color: #fff; padding: 7px 14px; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; display: flex; justify-content: space-between; align-items: center; }
    .section-header .section-total { font-size: 10px; font-weight: 700; }

    /* Table */
    table { width: 100%; border-collapse: collapse; }
    thead th { background: #3949ab; color: #fff; padding: 5px 12px; text-align: left; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3px; }
    thead th.right { text-align: right; }
    tbody tr:nth-child(even) { background: #f5f7fa; }
    tbody tr:nth-child(odd) { background: #fff; }
    tbody td { padding: 4px 12px; font-size: 9.5px; border-bottom: 1px solid #e8eaf6; }
    tbody td.compte-num { color: #3949ab; font-weight: 600; width: 80px; }
    tbody td.montant { text-align: right; font-weight: 600; color: #1a237e; width: 120px; }
    tbody tr.empty td { color: #aaa; font-style: italic; padding: 8px 12px; }

    /* Subtotal rows */
    .subtotal-row td { background: #e8eaf6; font-weight: 700; color: #1a237e; font-size: 10px; padding: 6px 12px; border-top: 2px solid #9fa8da; border-bottom: 2px solid #9fa8da; }
    .subtotal-row td.right { text-align: right; }

    /* Result block */
    .result-block { margin-top: 18px; }
    .result-inner { display: flex; align-items: stretch; border: 2px solid #1a237e; border-radius: 4px; overflow: hidden; }
    .result-cell { flex: 1; padding: 14px 18px; text-align: center; }
    .result-cell .label { font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; color: #555; margin-bottom: 6px; }
    .result-cell .value { font-size: 15px; font-weight: 700; color: #1a237e; }
    .result-divider { width: 1px; background: #1a237e; }
    .result-net { flex: 1.2; padding: 14px 18px; text-align: center; }
    .result-net .label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .result-net .value { font-size: 18px; font-weight: 700; }
    .benefice { background: #e8f5e9; color: #2e7d32; }
    .benefice .label { color: #2e7d32; }
    .perte { background: #ffebee; color: #c62828; }
    .perte .label { color: #c62828; }
    .equilibre { background: #f5f5f5; color: #555; }
    .equilibre .label { color: #555; }

    /* Footer */
    .doc-footer { padding: 8px 24px; font-size: 8px; color: #666; display: flex; justify-content: space-between; border-top: 1px solid #e8eaf6; margin-top: 16px; }

    @media print {
      body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="header-left">
      <div class="company-name">{{company.name}}</div>
      <div class="company-details">
        {{#if company.address.street}}{{company.address.street}}, {{/if}}{{company.address.city}}{{#if company.address.country}}, {{company.address.country}}{{/if}}<br />
        {{#if company.phone}}Tel : {{company.phone}} &nbsp;|&nbsp; {{/if}}
        {{#if company.email}}{{company.email}}{{/if}}<br />
        {{#if company.ninea}}NINEA : {{company.ninea}}{{/if}}
        {{#if company.rccm}}&nbsp;|&nbsp; RCCM : {{company.rccm}}{{/if}}
      </div>
    </div>
    <div class="header-right">
      <div class="doc-title">COMPTE DE RESULTAT</div>
      <div class="doc-subtitle">SYSCOHADA — Plan Comptable OHADA</div>
      <div class="doc-meta">
        Exercice {{exercice}}<br />
        Genere le {{formatDate generatedAt}}
      </div>
    </div>
  </div>

  <!-- Meta band -->
  <div class="meta-band">
    <span>Exercice : {{exercice}}</span>
    <span>Unite : FCFA (XOF)</span>
    <span>Referentiel : SYSCOHADA</span>
    <span>Classes : 6 (Charges) / 7 (Produits)</span>
  </div>

  <div class="content">

    <!-- CHARGES (Classe 6) -->
    <div class="section">
      <div class="section-header">
        <span>CHARGES (Classe 6)</span>
        <span class="section-total">Total : {{formatMontant resultat.totalCharges}} FCFA</span>
      </div>
      <table>
        <thead>
          <tr>
            <th style="width:80px;">N° Compte</th>
            <th>Libelle du Compte</th>
            <th class="right" style="width:130px;">Montant (FCFA)</th>
          </tr>
        </thead>
        <tbody>
          {{#if resultat.charges.length}}
            {{#each resultat.charges}}
            <tr>
              <td class="compte-num">{{_id}}</td>
              <td>{{compteLibelle}}</td>
              <td class="montant">{{formatMontant montant}}</td>
            </tr>
            {{/each}}
          {{else}}
            <tr class="empty"><td colspan="3">Aucune charge enregistree sur cette periode</td></tr>
          {{/if}}
          <tr class="subtotal-row">
            <td colspan="2">TOTAL CHARGES</td>
            <td class="right">{{formatMontant resultat.totalCharges}} FCFA</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- PRODUITS (Classe 7) -->
    <div class="section">
      <div class="section-header">
        <span>PRODUITS (Classe 7)</span>
        <span class="section-total">Total : {{formatMontant resultat.totalProduits}} FCFA</span>
      </div>
      <table>
        <thead>
          <tr>
            <th style="width:80px;">N° Compte</th>
            <th>Libelle du Compte</th>
            <th class="right" style="width:130px;">Montant (FCFA)</th>
          </tr>
        </thead>
        <tbody>
          {{#if resultat.produits.length}}
            {{#each resultat.produits}}
            <tr>
              <td class="compte-num">{{_id}}</td>
              <td>{{compteLibelle}}</td>
              <td class="montant">{{formatMontant montant}}</td>
            </tr>
            {{/each}}
          {{else}}
            <tr class="empty"><td colspan="3">Aucun produit enregistre sur cette periode</td></tr>
          {{/if}}
          <tr class="subtotal-row">
            <td colspan="2">TOTAL PRODUITS</td>
            <td class="right">{{formatMontant resultat.totalProduits}} FCFA</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- RESULTAT NET -->
    <div class="result-block">
      <div class="result-inner">
        <div class="result-cell">
          <div class="label">Total Charges</div>
          <div class="value" style="color:#c62828;">{{formatMontant resultat.totalCharges}} FCFA</div>
        </div>
        <div class="result-divider"></div>
        <div class="result-cell">
          <div class="label">Total Produits</div>
          <div class="value" style="color:#2e7d32;">{{formatMontant resultat.totalProduits}} FCFA</div>
        </div>
        <div class="result-divider"></div>
        {{#if resultat.resultatNet}}
          {{#if (eq resultat.resultatNet 0)}}
            <div class="result-net equilibre">
              <div class="label">RESULTAT NET</div>
              <div class="value">0 FCFA — Equilibre</div>
            </div>
          {{else}}
            <div class="result-net {{#if (eq '' '')}}{{/if}}" style="{{#if resultat.resultatNet}}{{#if (add resultat.resultatNet 0)}}background:#e8f5e9;{{else}}background:#ffebee;{{/if}}{{/if}}flex:1.2;padding:14px 18px;text-align:center;">
              <div class="label" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;color:#1a237e;">RESULTAT NET</div>
              <div class="value" style="font-size:18px;font-weight:700;color:#1a237e;">{{formatMontant resultat.resultatNet}} FCFA</div>
            </div>
          {{/if}}
        {{else}}
          <div class="result-net equilibre">
            <div class="label">RESULTAT NET</div>
            <div class="value">0 FCFA</div>
          </div>
        {{/if}}
      </div>
    </div>

  </div>

  <!-- Document footer -->
  <div class="doc-footer">
    <span>Document genere le {{formatDate generatedAt}} — {{company.name}}</span>
    <span>SYSCOHADA / OHADA — Valeurs en FCFA (XOF)</span>
  </div>

</body>
</html>
